# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # Server-side only — never expose to client

# Anthropic (claim email generation)
ANTHROPIC_API_KEY=                # Server-side only

# AviationStack (flight delay verification)
AVIATIONSTACK_API_KEY=            # Server-side only

# Portone (포트원 / 구 아이엠포트) — https://admin.portone.io
# 콘솔 → 시스템 설정 → 내 식별코드 / REST API 키
NEXT_PUBLIC_PORTONE_IMP_CODE=     # 가맹점 식별코드 (imp_XXXXXXXXXX) — public OK
PORTONE_API_KEY=                  # REST API 키        — server-side only
PORTONE_API_SECRET=               # REST API Secret   — server-side only
SUBSCRIPTION_AMOUNT_KRW=9900      # 월 구독 금액 (원) — verify route와 반드시 일치

# Stripe (글로벌 결제 — optional if using Portone only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=                # Server-side only
STRIPE_WEBHOOK_SECRET=            # For /api/webhooks/stripe endpoint

# Cron security
# Vercel automatically sets Authorization: Bearer <CRON_SECRET> on scheduled requests.
# Generate with: openssl rand -base64 32
CRON_SECRET=                      # Server-side only — keep out of client bundles

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
